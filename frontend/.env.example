# Copie este archivo a .env.local y ajuste los valores (.env.local no se sube a git).

# Contraseña del certificado perla.pfx (Vite HTTPS en desarrollo).
VITE_DEV_CERT_PASS=

# Host público del túnel Cloudflare (HMR y recarga en tiempo real fuera del servidor).
VITE_DEV_PUBLIC_HOST=perlax.perla.work

# Desarrollo local: https://perla:5263/api
# Túnel Cloudflare: https://api-perlax.perla.work/api
# VITE_API_BASE_URL=https://api-perlax.perla.work/api
